# Environment Variables for RoofQuote
# Copy this file to .env and fill in the values

# Database (SEPARATE from GroundQuote)
DATABASE_URL="postgresql://username:password@localhost:5432/roofquote"

# Google Maps & Solar API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="your-google-maps-api-key"
GOOGLE_SOLAR_API_KEY="your-google-solar-api-key"

# Auth
AUTH_SECRET="your-super-secret-jwt-key-min-32-chars"

# Email (Resend)
RESEND_API_KEY="re_your_resend_api_key"
FROM_EMAIL="info@roofquote.com"

# SMS (Twilio) - Optional
TWILIO_ACCOUNT_SID="ACxxxxxxxx"
TWILIO_AUTH_TOKEN="your_auth_token"
TWILIO_PHONE_NUMBER="+15551234567"

# Stripe (Placeholder - using GroundQuote account initially)
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_your_publishable_key"
STRIPE_FLAT_RATE_PRICE_ID="price_your_flat_rate_price_id"
STRIPE_PPL_PRICE_ID="price_your_pay_per_lead_price_id"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3002"
